; ModuleID = 'test'
source_filename = "test"

@.str.0 = private unnamed_addr constant [4 x i8] c"hi\0A\00"

declare i32 @printf(ptr, ...)

define i32 @main() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call i32 (ptr, ...) @printf(ptr @.str.0)
  ret i32 0
}
