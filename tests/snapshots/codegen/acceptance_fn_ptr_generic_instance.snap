; ModuleID = 'test'
source_filename = "test"

define i32 @main() {
allocas:
  %f.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr @"id__$i32", ptr %f.1.slot, align 8
  %load = load ptr, ptr %f.1.slot, align 8
  %call = call i32 %load(i32 42)
  ret i32 %call
}

define i32 @"id__$i32"(i32 %x) {
allocas:
  %x.0.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 %x, ptr %x.0.slot, align 4
  %load = load i32, ptr %x.0.slot, align 4
  ret i32 %load
}
