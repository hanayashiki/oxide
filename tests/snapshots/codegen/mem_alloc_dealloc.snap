define ptr @"ox_alloc__$i32"() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call ptr @malloc(i64 4)
  ret ptr %call
}

define void @"ox_dealloc__$i32"(ptr %p) {
allocas:
  %p.2.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr %p, ptr %p.2.slot, align 8
  %load = load ptr, ptr %p.2.slot, align 8
  call void @free(ptr %load)
  ret void
}

