source_filename = "test"

define i32 @main() {
allocas:
  %p.0.slot = alloca ptr, align 8
  %v.1.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  %call = call ptr @"ox_alloc__$i32"()
  store ptr %call, ptr %p.0.slot, align 8
  %load = load ptr, ptr %p.0.slot, align 8
  store i32 7, ptr %load, align 4
  %load1 = load ptr, ptr %p.0.slot, align 8
  call void @llvm.memcpy.p0.p0.i64(ptr align 1 %v.1.slot, ptr align 1 %load1, i64 ptrtoint (ptr getelementptr (i32, ptr null, i32 1) to i64), i1 false)
  %load2 = load ptr, ptr %p.0.slot, align 8
  call void @"ox_dealloc__$i32"(ptr %load2)
  %load3 = load i32, ptr %v.1.slot, align 4
  ret i32 %load3
}

declare ptr @malloc(i64)

declare ptr @calloc(i64, i64)

declare ptr @realloc(ptr, i64)

