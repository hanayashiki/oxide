; ModuleID = 'test'
source_filename = "test"

@.str.0 = private unnamed_addr constant [16 x i8] c"a=%d b=%d c=%d\0A\00"

declare i32 @printf(ptr, ...)

define i32 @main() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call i32 (ptr, ...) @printf(ptr @.str.0, i32 1, i32 2, i32 3)
  ret i32 0
}
