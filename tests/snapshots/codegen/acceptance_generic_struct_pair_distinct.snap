; ModuleID = 'test'
source_filename = "test"

%"Pair<i32, u8>" = type { i32, i8 }
%"Pair<u8, i32>" = type { i8, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %"Pair<i32, u8>", align 8
  %q.1.slot = alloca %"Pair<u8, i32>", align 8
  br label %body

body:                                             ; preds = %allocas
  store %"Pair<i32, u8>" { i32 1, i8 2 }, ptr %p.0.slot, align 4
  store %"Pair<u8, i32>" { i8 3, i32 4 }, ptr %q.1.slot, align 4
  %fld.gep = getelementptr inbounds %"Pair<i32, u8>", ptr %p.0.slot, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep, align 4
  %fld.gep1 = getelementptr inbounds %"Pair<u8, i32>", ptr %q.1.slot, i32 0, i32 1
  %fld.load2 = load i32, ptr %fld.gep1, align 4
  %add = add i32 %fld.load, %fld.load2
  ret i32 %add
}
