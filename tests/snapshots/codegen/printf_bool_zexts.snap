; ModuleID = 'test'
source_filename = "test"

@.str.0 = private unnamed_addr constant [8 x i8] c"b = %d\0A\00"

declare i32 @printf(ptr, ...)

define i32 @main() {
allocas:
  %b.1.slot = alloca i1, align 1
  br label %body

body:                                             ; preds = %allocas
  store i1 true, ptr %b.1.slot, align 1
  %load = load i1, ptr %b.1.slot, align 1
  %zext = zext i1 %load to i32
  %call = call i32 (ptr, ...) @printf(ptr @.str.0, i32 %zext)
  ret i32 0
}
