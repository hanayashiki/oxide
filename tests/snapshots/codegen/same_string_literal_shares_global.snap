; ModuleID = 'test'
source_filename = "test"

@.str.0 = private unnamed_addr constant [3 x i8] c"hi\00"

declare i32 @puts(ptr)

define i32 @main() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call i32 @puts(ptr @.str.0)
  %call1 = call i32 @puts(ptr @.str.0)
  ret i32 0
}
