== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @main() {
allocas:
  %x.0.slot = alloca i32, align 4
  %p.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store i32 0, ptr %x.0.slot, align 4
  store ptr %x.0.slot, ptr %p.1.slot, align 8
  %load = load ptr, ptr %p.1.slot, align 8
  store i32 42, ptr %load, align 4
  %load1 = load ptr, ptr %p.1.slot, align 8
  %ret.load = load i32, ptr %load1, align 4
  ret i32 %ret.load
}
== result ==
42
