== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%S = type { i32, i32 }

define i32 @main() {
allocas:
  %s.0.slot = alloca %S, align 8
  br label %body

body:                                             ; preds = %allocas
  store %S { i32 1, i32 2 }, ptr %s.0.slot, align 4
  store %S { i32 9, i32 8 }, ptr %s.0.slot, align 4
  %fld.gep = getelementptr inbounds %S, ptr %s.0.slot, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep, align 4
  %fld.gep1 = getelementptr inbounds %S, ptr %s.0.slot, i32 0, i32 1
  %fld.load2 = load i32, ptr %fld.gep1, align 4
  %add = add i32 %fld.load, %fld.load2
  ret i32 %add
}
== result ==
17
