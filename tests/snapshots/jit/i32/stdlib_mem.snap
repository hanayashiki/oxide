== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @main() {
allocas:
  %i.0.slot = alloca i32, align 4
  %p.1.slot = alloca ptr, align 8
  %if.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 0, ptr %i.0.slot, align 4
  store ptr %i.0.slot, ptr %p.1.slot, align 8
  %load = load ptr, ptr %p.1.slot, align 8
  %call = call i1 @"ox_is_null__$i32"(ptr %load)
  br i1 %call, label %logic.rhs, label %logic.end

logic.rhs:                                        ; preds = %body
  %load1 = load ptr, ptr %p.1.slot, align 8
  %call2 = call i1 @"ox_is_not_null__$i32"(ptr %load1)
  %not = xor i1 %call2, true
  br label %logic.end

logic.end:                                        ; preds = %logic.rhs, %body
  %logic = phi i1 [ false, %body ], [ %not, %logic.rhs ]
  br i1 %logic, label %if.then, label %if.else

if.then:                                          ; preds = %logic.end
  store i32 1, ptr %if.slot, align 4
  br label %if.end

if.else:                                          ; preds = %logic.end
  store i32 2, ptr %if.slot, align 4
  br label %if.end

if.end:                                           ; preds = %if.else, %if.then
  %if.val = load i32, ptr %if.slot, align 4
  ret i32 %if.val
}

declare ptr @malloc(i64)

declare ptr @calloc(i64, i64)

declare ptr @realloc(ptr, i64)

declare void @free(ptr)

declare ptr @aligned_alloc(i64, i64)

declare void @exit(i32)

declare void @_Exit(i32)

declare void @quick_exit(i32)

declare void @abort()

declare i32 @atoi(ptr)

declare i64 @atoll(ptr)

declare i32 @abs(i32)

declare i64 @llabs(i64)

declare i32 @rand()

declare void @srand(i32)

declare ptr @getenv(ptr)

declare i32 @system(ptr)

define i1 @"ox_is_null__$i32"(ptr %p) {
allocas:
  %p.9.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr %p, ptr %p.9.slot, align 8
  %load = load ptr, ptr %p.9.slot, align 8
  %call = call i1 @"ox_ptr_eq__$i32"(ptr %load, ptr null)
  ret i1 %call
}

define i1 @"ox_is_not_null__$i32"(ptr %p) {
allocas:
  %p.10.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr %p, ptr %p.10.slot, align 8
  %load = load ptr, ptr %p.10.slot, align 8
  %call = call i1 @"ox_is_null__$i32"(ptr %load)
  %not = xor i1 %call, true
  ret i1 %not
}

define i1 @"ox_ptr_eq__$i32"(ptr %a, ptr %b) {
allocas:
  %a.5.slot = alloca ptr, align 8
  %b.6.slot = alloca ptr, align 8
  %ai.7.slot = alloca i64, align 8
  %bi.8.slot = alloca i64, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr %a, ptr %a.5.slot, align 8
  store ptr %b, ptr %b.6.slot, align 8
  %load = load ptr, ptr %a.5.slot, align 8
  %transmute.p2i = ptrtoint ptr %load to i64
  store i64 %transmute.p2i, ptr %ai.7.slot, align 4
  %load1 = load ptr, ptr %b.6.slot, align 8
  %transmute.p2i2 = ptrtoint ptr %load1 to i64
  store i64 %transmute.p2i2, ptr %bi.8.slot, align 4
  %load3 = load i64, ptr %ai.7.slot, align 4
  %load4 = load i64, ptr %bi.8.slot, align 4
  %eq = icmp eq i64 %load3, %load4
  ret i1 %eq
}
== result ==
2
