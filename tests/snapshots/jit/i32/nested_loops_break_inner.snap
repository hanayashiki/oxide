== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @main() {
allocas:
  %total.0.slot = alloca i32, align 4
  %i.1.slot = alloca i32, align 4
  %j.2.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 0, ptr %total.0.slot, align 4
  store i32 0, ptr %i.1.slot, align 4
  br label %loop.cond

loop.body:                                        ; preds = %loop.cond
  store i32 0, ptr %j.2.slot, align 4
  br label %loop.body1

loop.end:                                         ; preds = %loop.cond
  %load9 = load i32, ptr %total.0.slot, align 4
  ret i32 %load9

loop.cond:                                        ; preds = %loop.end2, %body
  %load = load i32, ptr %i.1.slot, align 4
  %lt = icmp slt i32 %load, 3
  br i1 %lt, label %loop.body, label %loop.end

loop.body1:                                       ; preds = %if.end, %loop.body
  %load3 = load i32, ptr %j.2.slot, align 4
  %eq = icmp eq i32 %load3, 2
  br i1 %eq, label %if.then, label %if.else

loop.end2:                                        ; preds = %if.then
  %load7 = load i32, ptr %i.1.slot, align 4
  %add8 = add i32 %load7, 1
  store i32 %add8, ptr %i.1.slot, align 4
  br label %loop.cond

if.then:                                          ; preds = %loop.body1
  br label %loop.end2

if.else:                                          ; preds = %loop.body1
  br label %if.end

if.end:                                           ; preds = %if.else
  %load4 = load i32, ptr %total.0.slot, align 4
  %add = add i32 %load4, 1
  store i32 %add, ptr %total.0.slot, align 4
  %load5 = load i32, ptr %j.2.slot, align 4
  %add6 = add i32 %load5, 1
  store i32 %add6, ptr %j.2.slot, align 4
  br label %loop.body1
}
== result ==
6
