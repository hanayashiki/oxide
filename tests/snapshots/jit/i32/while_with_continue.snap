== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @main() {
allocas:
  %s.0.slot = alloca i32, align 4
  %i.1.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 0, ptr %s.0.slot, align 4
  store i32 0, ptr %i.1.slot, align 4
  br label %loop.cond

loop.body:                                        ; preds = %loop.cond
  %load1 = load i32, ptr %i.1.slot, align 4
  %add = add i32 %load1, 1
  store i32 %add, ptr %i.1.slot, align 4
  %load2 = load i32, ptr %i.1.slot, align 4
  %eq = icmp eq i32 %load2, 5
  br i1 %eq, label %if.then, label %if.else

loop.end:                                         ; preds = %loop.cond
  %load6 = load i32, ptr %s.0.slot, align 4
  ret i32 %load6

loop.cond:                                        ; preds = %if.end, %if.then, %body
  %load = load i32, ptr %i.1.slot, align 4
  %lt = icmp slt i32 %load, 10
  br i1 %lt, label %loop.body, label %loop.end

if.then:                                          ; preds = %loop.body
  br label %loop.cond

if.else:                                          ; preds = %loop.body
  br label %if.end

if.end:                                           ; preds = %if.else
  %load3 = load i32, ptr %s.0.slot, align 4
  %load4 = load i32, ptr %i.1.slot, align 4
  %add5 = add i32 %load3, %load4
  store i32 %add5, ptr %s.0.slot, align 4
  br label %loop.cond
}
== result ==
50
