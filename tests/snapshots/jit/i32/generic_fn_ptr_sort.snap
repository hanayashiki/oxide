define void @"sort__$i32"(ptr %arr, i64 %n, ptr %cmp) {
allocas:
  %arr.2.slot = alloca ptr, align 8
  %n.3.slot = alloca i64, align 8
  %cmp.4.slot = alloca ptr, align 8
  %sorted.5.slot = alloca i1, align 1
  %i.6.slot = alloca i64, align 8
  %cmp_result.7.slot = alloca i32, align 4
  %tmp.8.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store ptr %arr, ptr %arr.2.slot, align 8
  store i64 %n, ptr %n.3.slot, align 4
  store ptr %cmp, ptr %cmp.4.slot, align 8
  store i1 false, ptr %sorted.5.slot, align 1
  br label %loop.cond

loop.body:                                        ; preds = %loop.cond
  store i1 true, ptr %sorted.5.slot, align 1
  br label %loop.init

loop.end:                                         ; preds = %loop.cond
  ret void

loop.cond:                                        ; preds = %loop.end2, %body
  %load = load i1, ptr %sorted.5.slot, align 1
  %not = xor i1 %load, true
  br i1 %not, label %loop.body, label %loop.end

loop.body1:                                       ; preds = %loop.cond3
  %load6 = load ptr, ptr %cmp.4.slot, align 8
  %load7 = load ptr, ptr %arr.2.slot, align 8
  %load8 = load i64, ptr %i.6.slot, align 4
  %idx.gep = getelementptr inbounds i32, ptr %load7, i64 %load8
  %load9 = load ptr, ptr %arr.2.slot, align 8
  %load10 = load i64, ptr %i.6.slot, align 4
  %add = add i64 %load10, 1
  %idx.gep11 = getelementptr inbounds i32, ptr %load9, i64 %add
  %call = call i32 %load6(ptr %idx.gep, ptr %idx.gep11)
  store i32 %call, ptr %cmp_result.7.slot, align 4
  %load12 = load i32, ptr %cmp_result.7.slot, align 4
  %gt = icmp sgt i32 %load12, 0
  br i1 %gt, label %if.then, label %if.else

loop.end2:                                        ; preds = %loop.cond3
  br label %loop.cond

loop.init:                                        ; preds = %loop.body
  store i64 0, ptr %i.6.slot, align 4
  br label %loop.cond3

loop.cond3:                                       ; preds = %loop.update, %loop.init
  %load4 = load i64, ptr %i.6.slot, align 4
  %load5 = load i64, ptr %n.3.slot, align 4
  %sub = sub i64 %load5, 1
  %lt = icmp ult i64 %load4, %sub
  br i1 %lt, label %loop.body1, label %loop.end2

loop.update:                                      ; preds = %if.end
  %asgn.cur = load i64, ptr %i.6.slot, align 4
  %asgn.add = add i64 %asgn.cur, 1
  store i64 %asgn.add, ptr %i.6.slot, align 4
  br label %loop.cond3

if.then:                                          ; preds = %loop.body1
  %load13 = load ptr, ptr %arr.2.slot, align 8
  %load14 = load i64, ptr %i.6.slot, align 4
  %add15 = add i64 %load14, 1
  %idx.gep16 = getelementptr inbounds i32, ptr %load13, i64 %add15
  %idx.load = load i32, ptr %idx.gep16, align 4
  store i32 %idx.load, ptr %tmp.8.slot, align 4
  %load17 = load ptr, ptr %arr.2.slot, align 8
  %load18 = load i64, ptr %i.6.slot, align 4
  %idx.gep19 = getelementptr inbounds i32, ptr %load17, i64 %load18
  %idx.load20 = load i32, ptr %idx.gep19, align 4
  %load21 = load ptr, ptr %arr.2.slot, align 8
  %load22 = load i64, ptr %i.6.slot, align 4
  %add23 = add i64 %load22, 1
  %idx.gep24 = getelementptr inbounds i32, ptr %load21, i64 %add23
  store i32 %idx.load20, ptr %idx.gep24, align 4
  %load25 = load i32, ptr %tmp.8.slot, align 4
  %load26 = load ptr, ptr %arr.2.slot, align 8
  %load27 = load i64, ptr %i.6.slot, align 4
  %idx.gep28 = getelementptr inbounds i32, ptr %load26, i64 %load27
  store i32 %load25, ptr %idx.gep28, align 4
  store i1 false, ptr %sorted.5.slot, align 1
  br label %if.end

if.else:                                          ; preds = %loop.body1
  br label %if.end

if.end:                                           ; preds = %if.else, %if.then
  br label %loop.update
}

