; ModuleID = 'jit'
source_filename = "jit"

define i32 @cmp(ptr %a, ptr %b) {
allocas:
  %a.0.slot = alloca ptr, align 8
  %b.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store ptr %a, ptr %a.0.slot, align 8
  store ptr %b, ptr %b.1.slot, align 8
  %load = load ptr, ptr %a.0.slot, align 8
  %load1 = load ptr, ptr %b.1.slot, align 8
  %load2 = load i32, ptr %load, align 4
  %load3 = load i32, ptr %load1, align 4
  %sub = sub i32 %load2, %load3
  ret i32 %sub
}

define i32 @main() {
allocas:
  %to_sort.9.slot = alloca [3 x i32], align 4
  %lit.slot = alloca [3 x i32], align 4
  %length.10.slot = alloca i64, align 8
  br label %body

body:                                             ; preds = %allocas
  %lit.gep = getelementptr inbounds [3 x i32], ptr %lit.slot, i64 0, i64 0
  store i32 3, ptr %lit.gep, align 4
  %lit.gep1 = getelementptr inbounds [3 x i32], ptr %lit.slot, i64 0, i64 1
  store i32 2, ptr %lit.gep1, align 4
  %lit.gep2 = getelementptr inbounds [3 x i32], ptr %lit.slot, i64 0, i64 2
  store i32 1, ptr %lit.gep2, align 4
  call void @llvm.memcpy.p0.p0.i64(ptr align 1 %to_sort.9.slot, ptr align 1 %lit.slot, i64 ptrtoint (ptr getelementptr ([3 x i32], ptr null, i32 1) to i64), i1 false)
  store i64 3, ptr %length.10.slot, align 4
  %load = load i64, ptr %length.10.slot, align 4
  call void @"sort__$i32"(ptr %to_sort.9.slot, i64 %load, ptr @cmp)
  %load3 = load i64, ptr %length.10.slot, align 4
  %sub = sub i64 %load3, 1
  %bounds.cmp = icmp uge i64 %sub, 3
  br i1 %bounds.cmp, label %bounds.trap, label %bounds.ok

bounds.trap:                                      ; preds = %body
  call void @llvm.trap()
  unreachable

bounds.ok:                                        ; preds = %body
  %idx.gep = getelementptr inbounds [3 x i32], ptr %to_sort.9.slot, i64 0, i64 %sub
  %idx.load = load i32, ptr %idx.gep, align 4
  ret i32 %idx.load
}

