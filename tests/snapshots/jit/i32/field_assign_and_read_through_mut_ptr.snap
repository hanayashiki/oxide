== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%P = type { i32, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %P, align 8
  %q.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store %P zeroinitializer, ptr %p.0.slot, align 4
  store ptr %p.0.slot, ptr %q.1.slot, align 8
  %deref = load ptr, ptr %q.1.slot, align 8
  %fld.gep = getelementptr inbounds %P, ptr %deref, i32 0, i32 0
  store i32 10, ptr %fld.gep, align 4
  %deref1 = load ptr, ptr %q.1.slot, align 8
  %fld.gep2 = getelementptr inbounds %P, ptr %deref1, i32 0, i32 1
  store i32 20, ptr %fld.gep2, align 4
  %deref3 = load ptr, ptr %q.1.slot, align 8
  %fld.gep4 = getelementptr inbounds %P, ptr %deref3, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep4, align 4
  %deref5 = load ptr, ptr %q.1.slot, align 8
  %fld.gep6 = getelementptr inbounds %P, ptr %deref5, i32 0, i32 1
  %fld.load7 = load i32, ptr %fld.gep6, align 4
  %add = add i32 %fld.load, %fld.load7
  ret i32 %add
}
== result ==
30
