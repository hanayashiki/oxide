== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%Point = type { i32, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %Point, align 8
  br label %body

body:                                             ; preds = %allocas
  store %Point { i32 3, i32 4 }, ptr %p.0.slot, align 4
  %fld.gep = getelementptr inbounds %Point, ptr %p.0.slot, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep, align 4
  ret i32 %fld.load
}
== result ==
3
