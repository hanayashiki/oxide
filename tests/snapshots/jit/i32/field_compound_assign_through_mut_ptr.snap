== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%P = type { i32, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %P, align 8
  %q.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store %P { i32 7, i32 0 }, ptr %p.0.slot, align 4
  store ptr %p.0.slot, ptr %q.1.slot, align 8
  %deref = load ptr, ptr %q.1.slot, align 8
  %fld.gep = getelementptr inbounds %P, ptr %deref, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep, align 4
  %add = add i32 %fld.load, 3
  %deref1 = load ptr, ptr %q.1.slot, align 8
  %fld.gep2 = getelementptr inbounds %P, ptr %deref1, i32 0, i32 0
  store i32 %add, ptr %fld.gep2, align 4
  %fld.gep3 = getelementptr inbounds %P, ptr %p.0.slot, i32 0, i32 0
  %fld.load4 = load i32, ptr %fld.gep3, align 4
  ret i32 %fld.load4
}
== result ==
10
