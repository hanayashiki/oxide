== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @add_via_id(i32 %a, i32 %b) {
allocas:
  %a.1.slot = alloca i32, align 4
  %b.2.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 %a, ptr %a.1.slot, align 4
  store i32 %b, ptr %b.2.slot, align 4
  %load = load i32, ptr %a.1.slot, align 4
  %call = call i32 @"id__$i32"(i32 %load)
  %load1 = load i32, ptr %b.2.slot, align 4
  %call2 = call i32 @"id__$i32"(i32 %load1)
  %add = add i32 %call, %call2
  ret i32 %add
}

define i32 @main() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call i32 @add_via_id(i32 40, i32 2)
  ret i32 %call
}

define i32 @"id__$i32"(i32 %x) {
allocas:
  %x.0.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 %x, ptr %x.0.slot, align 4
  %load = load i32, ptr %x.0.slot, align 4
  ret i32 %load
}
