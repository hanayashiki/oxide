== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @add(i32 %a, i32 %b) {
allocas:
  %a.0.slot = alloca i32, align 4
  %b.1.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store i32 %a, ptr %a.0.slot, align 4
  store i32 %b, ptr %b.1.slot, align 4
  %load = load i32, ptr %a.0.slot, align 4
  %load1 = load i32, ptr %b.1.slot, align 4
  %add = add i32 %load, %load1
  ret i32 %add
}

define i32 @apply(ptr %f, i32 %x, i32 %y) {
allocas:
  %f.2.slot = alloca ptr, align 8
  %x.3.slot = alloca i32, align 4
  %y.4.slot = alloca i32, align 4
  br label %body

body:                                             ; preds = %allocas
  store ptr %f, ptr %f.2.slot, align 8
  store i32 %x, ptr %x.3.slot, align 4
  store i32 %y, ptr %y.4.slot, align 4
  %load = load ptr, ptr %f.2.slot, align 8
  %load1 = load i32, ptr %x.3.slot, align 4
  %load2 = load i32, ptr %y.4.slot, align 4
  %call = call i32 %load(i32 %load1, i32 %load2)
  ret i32 %call
}

define i32 @main() {
allocas:
  br label %body

body:                                             ; preds = %allocas
  %call = call i32 @apply(ptr @add, i32 1, i32 2)
  ret i32 %call
}
== result ==
3
