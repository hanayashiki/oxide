== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%Point = type { i32, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %Point, align 8
  %_q.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store %Point { i32 11, i32 22 }, ptr %p.0.slot, align 4
  %fld.gep = getelementptr inbounds %Point, ptr %p.0.slot, i32 0, i32 0
  store ptr %fld.gep, ptr %_q.1.slot, align 8
  %fld.gep1 = getelementptr inbounds %Point, ptr %p.0.slot, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep1, align 4
  ret i32 %fld.load
}
== result ==
11
