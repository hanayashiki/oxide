== ir ==
; ModuleID = 'jit'
source_filename = "jit"

define i32 @main() {
allocas:
  %x.0.slot = alloca i32, align 4
  %p.1.slot = alloca ptr, align 8
  %_ignore.2.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store i32 7, ptr %x.0.slot, align 4
  store ptr %x.0.slot, ptr %p.1.slot, align 8
  %load = load ptr, ptr %p.1.slot, align 8
  store ptr %load, ptr %_ignore.2.slot, align 8
  %load1 = load i32, ptr %x.0.slot, align 4
  ret i32 %load1
}
== result ==
7
