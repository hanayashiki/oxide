== ir ==
; ModuleID = 'jit'
source_filename = "jit"

%Point = type { i32, i32 }

define i32 @main() {
allocas:
  %p.0.slot = alloca %Point, align 8
  %q.1.slot = alloca ptr, align 8
  br label %body

body:                                             ; preds = %allocas
  store %Point zeroinitializer, ptr %p.0.slot, align 4
  store ptr %p.0.slot, ptr %q.1.slot, align 8
  %load = load ptr, ptr %q.1.slot, align 8
  %fld.gep = getelementptr inbounds %Point, ptr %load, i32 0, i32 0
  store i32 7, ptr %fld.gep, align 4
  %load1 = load ptr, ptr %q.1.slot, align 8
  %fld.gep2 = getelementptr inbounds %Point, ptr %load1, i32 0, i32 0
  %fld.load = load i32, ptr %fld.gep2, align 4
  ret i32 %fld.load
}
== result ==
7
